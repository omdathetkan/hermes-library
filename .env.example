# Bibliotheek WISE plugin — environment variables
# Copy this to .env (or add to your existing .env) and fill in your values.

# ── Required ──────────────────────────────────────────────────────────────────

# Your library login credentials (KB Digital Membership / iWelcome account).
LIBRARY_USERNAME=your_username
LIBRARY_PASSWORD=your_password

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# Branch ID — the numeric ID of your home library branch.
# Find it in the URL when you browse your library's catalog:
#   https://bibliotheek.wise.oclc.org/wise-apps/opac/branch/XXXX/catalog/...
LIBRARY_BRANCH_ID=2850

# Library network ID — shown in the URL as e.g. /library/I285/...
LIBRARY_ID=I285
